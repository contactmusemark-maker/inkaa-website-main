{
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon.png|favicon.svg|opengraph.jpg|opengraph.png|opengraph-inkaa-icon-v2.png|robots.txt|sitemap.xml|site.webmanifest).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon.png|favicon.svg|opengraph.jpg|opengraph.png|opengraph-inkaa-icon-v2.png|site.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
